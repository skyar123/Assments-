{{!< default}}
<section class="page-hero" id="main-content">
  <div class="container" style="text-align:center;">
    <span class="overline">{{statusCode}}</span>
    <h1>{{#if errorMessage}}{{errorMessage}}{{else}}Page not found{{/if}}</h1>
    <p>The page you're looking for doesn't exist or has moved.</p>
    <div style="margin-top:32px; display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
      <a href="{{@site.url}}" class="btn btn-primary">Field Notes home <span class="arrow">&rarr;</span></a>
      <a href="https://www.connectedcirclescommunity.com" class="btn btn-outline">Main site</a>
    </div>
  </div>
</section>
